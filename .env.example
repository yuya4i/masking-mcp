# ============================================================
#  local-mask-mcp — environment overrides
# ============================================================
#
# Nothing in this file is strictly required. The gateway boots
# with sane defaults (see src/app/config.py) and auto-generates
# an admin bearer token on first run.
#
# `docker compose up` will work fine even if .env is missing,
# but keeping it around lets you pin per-deployment overrides.

# -------- OPTIONAL: admin bearer token --------
# If left unset the gateway generates a 32-byte URL-safe token
# on first request and persists it to `data/admin_token`
# (file mode 0600). Retrieve it from the host with:
#     cat data/admin_token
# Uncomment only if you want to force a specific value — e.g.
# to share one across team members or to rotate manually.
# ADMIN_TOKEN=

# -------- OPTIONAL: runtime behavior --------
# APP_PORT=8081
# DEFAULT_FILTER_ENABLED=true
# DEFAULT_FAIL_CLOSED=true
# DEFAULT_MASK_STRATEGY=tag        # tag | partial | hash

# -------- OPTIONAL: storage paths (usually set by the Dockerfile) --------
# AUDIT_LOG_PATH=./data/audit.jsonl
# RUNTIME_CONFIG_PATH=./data/runtime_config.json
# TEMP_DIR=./data/tmp
# ADMIN_TOKEN_PATH=./data/admin_token

# -------- OPTIONAL: provider catalog --------
# Uncomment only to add/remove providers or point base_url elsewhere.
# The default catalog lives in src/app/config.py (DEFAULT_PROVIDER_CATALOG).
# DEFAULT_PROVIDER_ID=openai
# DEFAULT_PROVIDER_CATALOG_JSON={"openai":{"provider_id":"openai","provider_type":"openai","base_url":"https://api.openai.com","enabled":true,"route_mode":"native","default_headers":{},"model_mapping":{}},"anthropic":{"provider_id":"anthropic","provider_type":"anthropic","base_url":"https://api.anthropic.com","enabled":true,"route_mode":"native","default_headers":{"anthropic-version":"2023-06-01"},"model_mapping":{}}}
