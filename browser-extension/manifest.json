{
  "manifest_version": 3,
  "name": "Local Mask MCP — PII Guard",
  "version": "0.4.0",
  "description": "Masks personal information in AI chat inputs before they leave your browser. Works standalone; optionally uses a local gateway for higher accuracy.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://*.claude.com/*",
    "https://chatgpt.com/*",
    "https://*.openai.com/*",
    "https://gemini.google.com/*",
    "https://*.manus.im/*",
    "http://127.0.0.1:8081/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://*.claude.com/*",
        "https://chatgpt.com/*",
        "https://*.openai.com/*",
        "https://gemini.google.com/*",
        "https://*.manus.im/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "injected.js",
        "review-modal.js",
        "sidebar.js",
        "engine/patterns.js",
        "engine/classification.js",
        "engine/severity.js",
        "engine/categories.js",
        "engine/aggregate.js",
        "engine/force-mask.js",
        "engine/blocklist.js",
        "engine/engine.js",
        "engine/bundle.js"
      ],
      "matches": [
        "https://claude.ai/*",
        "https://*.claude.com/*",
        "https://chatgpt.com/*",
        "https://*.openai.com/*",
        "https://gemini.google.com/*",
        "https://*.manus.im/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
