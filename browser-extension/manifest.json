{
  "manifest_version": 3,
  "name": "PII Guard (dev — local LLM)",
  "version": "1.4.0",
  "version_name": "0.5.1-dev",
  "description": "PII masking + optional local LLM proxy. Dev build (not for Web Store).",
  "permissions": ["storage", "activeTab", "offscreen"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://*.claude.com/*",
    "https://chatgpt.com/*",
    "https://*.openai.com/*",
    "https://gemini.google.com/*",
    "https://*.manus.im/*",
    "http://*/*",
    "https://huggingface.co/*",
    "https://cdn-lfs.huggingface.co/*",
    "https://cdn-lfs-us-1.hf.co/*"
  ],
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "content_security_policy": {
    "extension_pages": "script-src 'self' 'wasm-unsafe-eval'; object-src 'self'"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://*.claude.com/*",
        "https://chatgpt.com/*",
        "https://*.openai.com/*",
        "https://gemini.google.com/*",
        "https://*.manus.im/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "injected.js",
        "review-modal.js",
        "sidebar.js",
        "engine/dictionaries.js",
        "engine/patterns.js",
        "engine/classification.js",
        "engine/severity.js",
        "engine/categories.js",
        "engine/aggregate.js",
        "engine/force-mask.js",
        "engine/blocklist.js",
        "engine/user-force-mask.js",
        "engine/engine.js",
        "engine/bundle.js",
        "engine/surrogates.js",
        "engine/llm-prompts.js",
        "engine/onnx-detector.js",
        "vendor/transformers/transformers.min.js",
        "vendor/transformers/ort-wasm-simd-threaded.jsep.mjs",
        "vendor/transformers/ort-wasm-simd-threaded.jsep.wasm"
      ],
      "matches": [
        "https://claude.ai/*",
        "https://*.claude.com/*",
        "https://chatgpt.com/*",
        "https://*.openai.com/*",
        "https://gemini.google.com/*",
        "https://*.manus.im/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "options_ui": {
    "page": "options.html",
    "open_in_tab": true
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
