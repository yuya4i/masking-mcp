{
  "manifest_version": 3,
  "name": "Local Mask MCP — PII Guard",
  "version": "0.1.0",
  "description": "Masks personal information in AI chat inputs before they leave your browser. Requires local-mask-mcp gateway running at 127.0.0.1:8081.",
  "permissions": ["storage", "activeTab"],
  "host_permissions": [
    "https://claude.ai/*",
    "https://*.claude.com/*",
    "https://chatgpt.com/*",
    "https://chat.openai.com/*",
    "https://gemini.google.com/*",
    "https://*.manus.im/*",
    "https://manus.im/*",
    "http://127.0.0.1:8081/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://claude.ai/*",
        "https://*.claude.com/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://*.manus.im/*",
        "https://manus.im/*"
      ],
      "js": ["content.js"],
      "run_at": "document_start"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": ["injected.js", "review-modal.js", "sidebar.js"],
      "matches": [
        "https://claude.ai/*",
        "https://*.claude.com/*",
        "https://chatgpt.com/*",
        "https://chat.openai.com/*",
        "https://gemini.google.com/*",
        "https://*.manus.im/*",
        "https://manus.im/*"
      ]
    }
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
